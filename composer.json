{
    "name": "inovanti-bank/inovanti-toolkit",
    "description": "O Inovanti Toolkit é um componente desenvolvido para Laravel ^11, projetado para facilitar a resolução de demandas comuns em aplicações web. Seu principal objetivo é eliminar a necessidade de reescrever lógicas repetitivas, oferecendo um conjunto de funcionalidades otimizadas e reutilizáveis.",
    "type": "library",
    "require": {
      "php": "^8.0",
      "laravel/framework": "^11.0"
    },
    "autoload": {
      "psr-4": {
        "InovantiBank\\Toolkit\\": "src/"
      }
    },
    "autoload-dev": {
      "psr-4": {
        "Tests\\": "tests/"
      }
    },
    "extra": {
      "laravel": {
        "providers": [
          "InovantiBank\\Toolkit\\Providers\\ToolkitServiceProvider"
        ]
      }
    },
    "scripts": {
      "test": "vendor/bin/phpunit",
      "unit": "vendor/bin/phpunit --testsuite=Unit",
      "feature": "vendor/bin/phpunit --testsuite=Feature",
      "pint": "vendor/bin/pint"
    },
    "minimum-stability": "dev",
    "license": "MIT",
    "authors": [
      {
        "name": "inovanti Ip",
        "email": "dev@inovanti.com.br"
      }
    ],
    "require-dev": {
      "phpunit/phpunit": "^11.5",
      "mockery/mockery": "^1.6",
      "laravel/pint": "^1.19",
      "orchestra/testbench": "^9.0"
    },
    "keywords": [
      "laravel",
      "toolkit",
      "phpunit",
      "inovanti"
    ]
  }